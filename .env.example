# Abstract Network RPC Endpoints
ABSTRACT_RPC=https://api.mainnet.abs.xyz
ABSTRACT_TESTNET_RPC=https://api.testnet.abs.xyz

# Chain IDs
ABSTRACT_CHAIN_ID=2741
ABSTRACT_TESTNET_CHAIN_ID=11124

# Etherscan API Key (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# FileStore Address (same on both networks)
FILESTORE_ADDRESS=0xFe1411d6864592549AdE050215482e4385dFa0FB

# Deployer address (set after creating keystore)
DEPLOYER_ADDRESS=

# Note: Private keys are stored in Foundry's encrypted keystore
# Run: cast wallet import dealersKeystore --interactive
# Then use: --account dealersKeystore in deployment scripts
